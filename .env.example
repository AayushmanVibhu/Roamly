# Environment Variables Template
# Copy this file to .env.local for local development

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API Keys
SERPAPI_API_KEY=your_serpapi_key_here
# SKYSCANNER_API_KEY=your_api_key_here

# Watch checker + alerting
# WATCH_CHECK_SECRET=your_cron_secret_here
# RESEND_API_KEY=your_resend_api_key_here
# ALERT_FROM_EMAIL=alerts@yourdomain.com
# WATCH_STORE_PATH=/tmp/roamly-watches.json

# Database (for future use)
# DATABASE_URL=your_database_url_here

# Authentication (for future use)
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=your_nextauth_secret_here

# Email Service (for future price alerts)
# SENDGRID_API_KEY=your_sendgrid_key_here
# EMAIL_FROM=noreply@roamly.com

# Analytics (optional)
# GOOGLE_ANALYTICS_ID=your_ga_id_here
